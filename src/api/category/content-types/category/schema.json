      "target": "api::category.category",
      "inversedBy": "categories"
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "category"
    },
    "sizes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::size.size",
      "mappedBy": "category"
    },
    "category_attributes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category-attribute.category-attribute",
      "mappedBy": "categories"
    },
    "brands": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::brand.brand",
      "inversedBy": "categories"
    },
    "colors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::color.color",
      "inversedBy": "categories"
    },
    "conditions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::condition.condition",
      "inversedBy": "categories"
    },
    "materials": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::material.material",
      "mappedBy": "categories"
    }
  }
