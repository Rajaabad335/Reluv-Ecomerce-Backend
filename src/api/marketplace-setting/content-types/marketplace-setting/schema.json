{
  "kind": "collectionType",
  "collectionName": "marketplace_settings",
  "info": {
    "singularName": "marketplace-setting",
    "pluralName": "marketplace-settings",
    "displayName": "marketplace_setting"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
   "attributes": {
    "commissionRate": {
      "type": "decimal",
      "required": true,
      "min": 0,
      "max": 100,
      "default": 10
    },
    "escrowDays": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 90,
      "default": 7
    },
    "currency": {
      "type": "string",
      "required": true,
      "default": "THB",
      "maxLength": 3
    },
    "stripePublishableKey": {
      "type": "string"
    },
    "stripeSecretKey": {
      "type": "string",
      "private": true
    },
    "stripeWebhookSecret": {
      "type": "string",
      "private": true
    },
    "autoPayoutEnabled": {
      "type": "boolean",
      "default": false
    },
    "autoPayoutThresholdAmount": {
      "type": "decimal",
      "default": 0,
      "min": 0
    },
    "maintenanceMode": {
      "type": "boolean",
      "default": false
    },
    "maintenanceMessage": {
      "type": "text"
    }
  }

}
