{
  "kind": "collectionType",
  "collectionName": "category_attributes",
  "info": {
    "singularName": "category-attribute",
    "pluralName": "category-attributes",
    "displayName": "category-attribute"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "string",
        "number",
        "boolean",
        "enum"
      ]
    },
    "isRequired": {
      "type": "boolean"
    },
    "code": {
      "type": "string"
    },
    "placeholder": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "displayType": {
      "type": "enumeration",
      "default": "text",
      "enum": [
        "text",
        "list",
        "number",
        "boolean"
      ]
    },
    "selectionType": {
      "type": "enumeration",
      "default": "single",
      "enum": [
        "single",
        "multiple"
      ]
    },
    "selectionLimit": {
      "type": "integer"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "category_attributes"
    },
    "category_attribute_options": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category-attribute-option.category-attribute-option",
      "mappedBy": "category_attribute"
    },
    "product_attribute_values": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product-attribute-value.product-attribute-value",
      "mappedBy": "category_attribute"
    }
  }
}
