{
  "kind": "collectionType",
  "collectionName": "offers",
  "info": {
    "singularName": "offer",
    "pluralName": "offers",
    "displayName": "Offer"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "offerPrice": {
      "type": "decimal",
      "required": true
    },
    "originalPrice": {
      "type": "decimal",
      "required": true
    },
    "message": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "accepted", "declined", "expired"],
      "default": "pending",
      "required": true
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product"
    },
    "buyer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "seller": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "productTitle": { "type": "string" },
    "productImage": { "type": "string" }
  }
}
