{
  "kind": "collectionType",
  "collectionName": "disputes",
  "info": {
    "singularName": "dispute",
    "pluralName": "disputes",
    "displayName": "dispute"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
   "attributes": {
    "order": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::order.order"
    },
    "raisedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "recievedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "reason": {
      "type": "enumeration",
      "enum": [
        "ITEM_NOT_RECEIVED",
        "DAMAGED_PRODUCT",
        "WRONG_ITEM",
        "PAYMENT_ISSUE"
      ]
    },
    "description": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "OPEN",
        "UNDER_REVIEW",
        "RESOLVED",
        "REJECTED",
        "CLOSED"
      ],
      "default": "OPEN"
    },
    "resolution": {
      "type": "text"
    },
    "refundAmount": {
      "type": "decimal"
    }
  }
}
